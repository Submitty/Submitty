{% if notice is not null %}
    <div class="rg-build-notice rg-build-notice-{{ notice.level }}" data-testid="rainbow-build-notice">
        {% for message in notice.messages %}
            <p>{{ message }}</p>
        {% endfor %}
        {% if notice.sysadmin_email is not empty %}
            <p class="rg-build-notice-contact">
                Contact your system administrator at
                <a href="mailto:{{ notice.sysadmin_email }}">{{ notice.sysadmin_email }}</a>
                for assistance.
            </p>
        {% endif %}
    </div>
{% endif %}
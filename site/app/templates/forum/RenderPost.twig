{% if render_markdown %}
    {% include "Vue.twig" with {
        type: "component",
        name: "Markdown",
        args: {
            content: post_content
        }
    } only %}
{% else %}
    {{- post_content -}}
{% endif %}
{% if post_attachment is defined and post_attachment.exist == true %}
    <table>
        <tbody class="history-attachment-table" id="history-table-{{ edit_id }}">
            {% for attachment in post_attachment.params.unencoded_data %}
                {% if attachment[2] is defined %}
                    <tr>
                        <td style="padding: 20px">
                            {% if attachment[3] is defined and attachment[3] == 'pdf' %}
                                <div class="attachment-pdf">
                                    <a href="{{ attachment[0] }}" target="_blank" rel="noopener noreferrer" class="btn btn-default attachment-open-btn">Open PDF</a>
                                    <iframe
                                        src="{{ attachment[0] }}"
                                        title="PDF attachment preview for {{ attachment[2] }}"
                                        class="attachment-pdf-preview"
                                    ></iframe>
                                </div>
                            {% else %}
                                <a href="{{ attachment[0] }}" target="_blank" rel="noopener noreferrer">
                                    <img
                                        src="{{ attachment[0] }}"
                                        alt="Click to view attachment in a new tab"
                                        title="Click to view attachment in a new tab"
                                        class="attachment-img"
                                    />
                                </a>
                            {% endif %}
                        </td>
                        <td class="attachment-name-history">{{ attachment[2] }}</td>
                    </tr>
                {% endif %}
            {% endfor %}
        </tbody>
    </table>
    <a class="btn btn-default history-attachment-btn" onclick="displayHistoryAttachment('{{ edit_id }}')">
        Attachments
        <span class="attachment-badge badge">{{ post_attachment.params.num_files }}</span>
    </a>
{% endif %}

{% extends 'generic/Popup.twig' %}
{% block popup_id %}sync-notification-popup{% endblock %}
{% block title %}
    Sync Notification Settings
{% endblock %}
{% block body %}
<div class="form-group mt-3">
    <label class="font-weight-bold text-dark">
        Select courses to copy the current notification settings to:
    </label>
    <div class="border rounded p-2 bg-white text-dark"
         style="max-height: 250px; overflow-y: auto;">
        {% if courses is empty %}
            <div class="text-muted">
                No courses available.
            </div>
        {% else %}
            {% for course in courses %}
                <div class="form-check mb-1">
                    <input
                        class="form-check-input"
                        type="checkbox"
                        name="sync_course_ids[]"
                        value="{{ course.getCourse() ~ '_' ~ course.getTerm() }}"
                        id="course_{{ loop.index }}"
                    >
                    <label class="form-check-label" for="course_{{ loop.index }}">
                        {{ course.getCourse() }} ({{ course.getTerm() }})
                        — {{ course.getTitle() }}
                    </label>
                </div>
            {% endfor %}
        {% endif %}
    </div>
</div>
{% endblock %}
{% block buttons %}
<button class="btn btn-primary" onclick="setNotification()">
    Sync Settings
</button>

{{ block('close_button') }}
{% endblock %}
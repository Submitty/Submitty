{#
Macro for rendering SortableColumn.vue within Twig
#}

{# using_row_groups is specifically for statPage.twig's forum post collapsible rows #}
{% macro sortable_header(table_id, title, sort_key, col_data_type, using_row_groups = false) %}
    {% set id = uniqid() %}
    <th id="vue-{{ id }}" data-col-title="{{ title }}">
    </th>
    <script>
        window.submitty.render(
            "#vue-{{ id }}",
            "component",
            "SortableColumn",
            {{ 
                { 
                    tableId: table_id, 
                    title: title, 
                    sortKey: sort_key, 
                    colDataType: col_data_type,
                    usingRowGroups: using_row_groups,
                } 
                | json_encode() | raw() 
            }},
            {}
        );
    </script>
{% endmacro %}

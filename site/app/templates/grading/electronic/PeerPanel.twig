<div id="peer_info" class="rubric_panel {{ is_ta_grading ? "" : "empty" }}" data-testid="peer-info">
    <div>
        {% if is_ta_grading %}
            <div id="rubric-container" class="container">
                <span class="col grading_label">Peer Grading
                    <button type="button" class="btn btn-primary" title="Edit Peer Components" aria-label="Edit Peer Components" onclick="newEditPeerComponentsForm()">
                        <i class="fas fa-pencil-alt" aria-hidden="true"></i>
                        Edit Peer Components
                    </button>
                </span>
                <div class="inner-container" id="peer-grading-box">
                    {% if has_active_version %}
                        <script>
                            $(document).ready(function () {
                                loadTemplates().then(function() {
                                    return reloadPeerRubric('{{ gradeable_id }}', '{{ anon_id }}');
                                });
                            });
                        </script>
                    {% else %}
                        <h4>No Submission</h4>
                    {% endif %}
                </div>
            </div>
        {% else %}
            <div id="no-manual-grading-container">
                <h3> No Manual Grading For This Assignment </h3>
            </div>
        {% endif %}
    </div>
</div>

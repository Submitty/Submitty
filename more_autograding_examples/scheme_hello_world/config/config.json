{
    "required_capabilities": "default",
    "autograding_method": "docker",

    "autograding": {
        "submission_to_runner": [
            "*.rkt",
            "**/*.rkt"
        ]
    },

    "container_options": {
        "container_image": "submitty/scheme:latest"
    },

    "testcases": [
        {
            "title": "Check output",
            "details": "Run Racket program",
            "command": "racket main.rkt",
            "points": 5,
            "validation": [
                {
                    "actual_file": "STDOUT.txt",
                    "method": "diff",
                    "comparison": "byLinebyChar",
                    "expected_string": "hello world\n"
                }
            ]
        }
    ]
}
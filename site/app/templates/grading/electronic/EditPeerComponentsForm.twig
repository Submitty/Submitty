{% extends 'generic/Popup.twig' %}
{% block popup_id %}edit-peer-components-form{% endblock %}
{% block title %}Edit Peer Components Form{% endblock %}
{% block body %}
    {% include 'Vue.twig' with {
        'type': 'component',
        'name': 'ta_grading/EditPeerComponentsForm',
        'args': {
            'peers': peers,
            'submitterId': submitter_id,
            'gradeableId': gradeable_id,
            'csrfToken': csrf_token,
            'components': components,
            'componentScores': component_scores,
            'peerDetails': peer_details,
            'marks': marks,
        }
    } %}
{% endblock %}

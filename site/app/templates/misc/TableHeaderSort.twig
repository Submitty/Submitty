{#
Function for sorting tables by ascending or descending
See sort-table-by-column.ts
#}

{% macro sortable_header(table_id, title, sort_key, col_data_type) %}
    <th>
        <a href="#"
        onclick="event.preventDefault(); sortTableByColumn('{{ table_id }}', '{{ sort_key }}', '{{ col_data_type }}');"
        class="sortable-header"
        data-sort-key="{{ sort_key }}">
            {{ title }}
            <i class="fa fa-sort"></i>
        </a>
    </th>
{% endmacro %}
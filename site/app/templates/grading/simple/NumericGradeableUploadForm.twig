{% extends 'generic/Popup.twig' %}
{% block popup_id %}numeric-csv-upload-form{% endblock %}
{% block title %}Upload Numeric Grade CSV{% endblock %}
{% block body %}
    <p>
        Upload a .csv file to update numeric/text grades. Uploading will overwrite existing values for included students.
    </p>
    <br>
    <p>
        List each numeric or text column you want to update, with a header matching the column name shown in the grading table. Only the columns you include will be updated — any others will be left unchanged.
    </p>
    <br>
    <p>
        Mandatory Columns:
    </p>
    <ol class="full-list">
        <li>"User ID"</li>
    </ol>
    <p>
        Optional Columns:
    </p>
    <ol class="full-list">
        <li>"Total" (if included, must equal sum of student's numeric points earned)</li>
    </ol>
    <p>
        All other columns are ignored.
    </p>
    <p>&emsp;</p>
    <input type="file" id="numeric-csv-upload-file" name="upload" accept=".xlsx, .csv" aria-label="Choose File">
{% endblock %}
{% block buttons %}
    {{ block('close_button') }}
    <input class="btn btn-primary" type="button" id="submit-numeric-csv-upload" value="Submit" />
{% endblock %}

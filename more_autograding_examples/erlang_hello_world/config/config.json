{
    "required_capabilities": "default",
    "autograding_method": "docker",
    "container_options": {
        "container_image": "erlang:26"
    },
    "grading_parameters": {
        "TOTAL_POINTS": 5,
        "AUTO_POINTS": 5
    },
    "resource_limits": {
        "RLIMIT_CPU": 10,
        "RLIMIT_NPROC": 100,
        "RLIMIT_SIGPENDING": 100
    },
    "allow_system_calls": [
        "PROCESS_CONTROL_MEMORY_ADVANCED",
        "PROCESS_CONTROL_NEW_PROCESS_THREAD",
        "PROCESS_CONTROL_SYNCHRONIZATION",
        "PROCESS_CONTROL_SCHEDULING",
        "PROCESS_CONTROL_ADVANCED",
        "FILE_MANAGEMENT_EXTENDED_ATTRIBUTES",
        "FILE_MANAGEMENT_RARE",
        "DEVICE_MANAGEMENT_ADVANCED",
        "INFORMATION_MAINTENANCE_ADVANCED",
        "COMMUNICATIONS_AND_NETWORKING_SOCKETS_MINIMAL",
        "COMMUNICATIONS_AND_NETWORKING_SOCKETS",
        "COMMUNICATIONS_AND_NETWORKING_SIGNALS",
        "COMMUNICATIONS_AND_NETWORKING_INTERPROCESS_COMMUNICATION"
    ],
    "autograding": {
        "submission_to_compilation": [
            "**/*.erl"
        ],
        "compilation_to_runner": [
            "**/*.beam"
        ]
    },
    "assignment_message": "Place your main module in hello.erl with function hello_world/0 that prints 'hello world'.",
    "testcases": [
        {
            "type": "Compilation",
            "title": "Compilation",
            "command": "erlc *.erl",
            "details": "Compiling Erlang source files",
            "executable_name": "hello.beam",
            "points": 2
        },
        {
            "title": "Output Check",
            "command": "erl -noshell -s hello hello_world -s init stop",
            "details": "Running hello_world/0 function from hello module",
            "points": 3,
            "validation": [
                {
                    "actual_file": "STDOUT.txt",
                    "method": "diff",
                    "comparison": "byLinebyChar",
                    "expected_string": "hello world\n"
                }
            ]
        }
    ]
}

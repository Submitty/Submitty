{% extends 'generic/Popup.twig' %}
{% block popup_id %}sync-notification-popup{% endblock %}
{% block title %}Sync Notification Settings{% endblock %}
{% block body %}
<div class="form-group sync-popup-body">
    <label>Select courses to copy the current notification settings to:</label>
    <hr />
    <div class="sync-course-list">
        {% for course in courses %}
            <div class="sync-course-container"
                 onclick="toggleSyncRow(this)">
                <div class="sync-course-grid">
                    <input type="checkbox"
                           class="sync-course-checkbox"
                           name="sync_course_ids[]"
                           value="{{ course.getTerm() }}|{{ course.getTitle() }}"
                           onclick="event.stopPropagation(); updateRowHighlight(this)">
                    <span>({{ course.getTerm() }})</span>
                    <span>{{ course.getTitle() }}</span>
                </div>
                <hr />
            </div>
        {% endfor %}
    </div>
    <div class="sync-buttons">
        <button type="button" class="btn btn-primary" onclick="selectAllSyncCourses()">Select All</button>
        <button type="button" class="btn btn-primary" onclick="clearAllSyncCourses()">Clear Selection</button>
    </div>
</div>
{% endblock %}
{% block buttons %}
<button class="btn btn-primary" onclick="setNotification(this)">
    Sync Settings
</button>
    {{block('close_button')}}
{% endblock %}
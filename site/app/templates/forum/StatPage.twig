{% import "misc/TableHeaderSort.twig" as sort %}

<div class="content forum_content">
    {% include "forum/ForumBar.twig" with {
        "forum_bar_buttons_right" : forumBarData.forum_bar_buttons_right,
        "forum_bar_buttons_left" : forumBarData.forum_bar_buttons_left,
        "show_threads" : forumBarData.show_threads,
        "thread_exists" : forumBarData.thread_exists,
        "categories": [],
        "show_filter": false,
        "show_more": false,
        "csrf_token": csrf_token,
        "activeThread": null
    } %}
    <div class="stats-table-container">
        <table class="table table-striped table-bordered persist-area" id="forum_stats_table">
            <thead>
                <tr>
                    {{ sort.sortable_header('User', 'user') }}
                    {{ sort.sortable_header('Total Posts (not deleted)', 'total_posts') }}
                    {{ sort.sortable_header('Total Threads', 'total_threads') }}
                    {{ sort.sortable_header('Total Deleted Posts', 'total_deleted') }}
                    {{ sort.sortable_header('Total Upducks', 'total_upducks') }}
                    <th>Show Posts</th>
                </tr>
            </thead>
            <tbody>
                {% for user in userData %}
                {# potential problem: if two users have the exact same name #}
                <tr data-testid="user-stat" class="user_stat">
                    <td>{{ user.family_name }}, {{ user.given_name }}</td>
                    <td>{{ user.post_count }}</td>
                    <td>{{ user.details_total_threads }}</td>
                    <td>{{ user.num_deleted }}</td>
                    <td data-testid="upduck-stat" class="upduck_stat">{{ user.total_upducks }}</td>
                    {% if user.posts %}
                        <td><button type="button" class="btn btn-default" data-action="expand" data-posts="{{ user.posts }}" data-id="{{ user.ids }}" data-timestamps="{{ user.timestamps }}" data-thread_id="{{ user.thread_ids }}" data-thread_titles="{{ user.thread_titles }}">Expand</button></td>
                    {% else %}
                        <td>No Posts</td>
                    {% endif %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

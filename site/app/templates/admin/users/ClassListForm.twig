{% extends 'generic/Popup.twig' %}
{% block popup_id %}class-list-form{% endblock %}
{% block title %}Upload Classlist{% endblock %}
{% block body %}
    <p>
        Format your student data as an .xlsx or .csv file with as many of the following columns as you want, and a header row:
    </p>
    <ol class="full-list">
        <li>"User ID": The user id associated with the student (mandatory).</li>
        <li>"Given Name": Only read for new students.</li>
        <li>"Family Name": Only read for new students.</li>
        <li>"Preferred Given Name": Only read for new students.</li>
        <li>"Preferred Family Name": Only read for new students.</li>
        <li>"Email": Only read for new students.</li>
        <li>"Secondary Email": Only read for new students.</li>
        <li>"Registration Section": For graders, this is a comma-separated list of sections in quotes, e.g. "10AM,11AM,12PM".</li>
        <li>"Registration Sub-Section": Can contain alphanumeric letters, spaces, hyphens or underscores.</li>
        <li>"Registration Type": "graded", "audit", "withdrawn", or "staff"</li>
        {% if use_database %}
            <li>"Password": Only works for new students on installations using database uploads.</li>
        {% endif %}
        <li>"Group": "Instructor" (1), "Full Access Grader (Grad TA)" (2), "Limited Access Grader (Mentor)" (3), or "Student" (4)</li>
        <li>"UTC Offset": Included for compatability with exported lists, ignored by this upload.</li>
        <li>"Time Zone": Included for compatability with exported lists, ignored by this upload.</li>
        <li>"Rotation Section": Included for compatability with exported lists, ignored by this upload.</li>
        <li>"Autofill Data": "TRUE" or "FALSE", if set for an existing user they will have their personal information automatically filled.</li>
    </ol>
    <p>
        For more formatting information, see
        <a target="_blank" href="https://submitty.org/instructor/course_management/managing_enrollment#add-students-by-bulk-file-csv-upload">
            Add Students by Bulk File CSV Upload <i style="font-style:normal;" class="fa-question-circle"></i>
        </a>
    </p>
    <br />
    <p>&emsp;</p>
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}" />
    <label class="std-margin" for="move_missing">
        Move students missing from the classlist to NULL section?
        <input type="checkbox" name="move_missing" id="move_missing" />
    </label>
    <input type="file" name="upload" accept=".xlsx, .csv" aria-label="Choose File">
{% endblock %}
{% block form %}
    <form method="post" action="{{ return_url_upload_class_list }}" enctype="multipart/form-data">
        {{ parent() }}
    </form>
{% endblock %}
{% block buttons %}
    {{ block('close_button') }}
    <input class="btn btn-primary" type="submit" value="Submit" />
{% endblock %}
